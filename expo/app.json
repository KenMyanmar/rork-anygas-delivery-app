{
  "expo": {
    "name": "AnyGas Delivery App",
    "slug": "anygas-delivery-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "anygas8484",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F97316"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.rork.anygas-delivery-app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#F97316"
      },
      "package": "app.rork.anygas_delivery_app"
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://www.anygas.org/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow AnyGas 8484 to use Face ID to unlock your account securely."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "AnyGas uses your location to save your delivery address."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "c13f53dd-cbf5-4cdd-8e99-4a45c322d7a7"
      }
    },
    "owner": "anygas"
  }
}
